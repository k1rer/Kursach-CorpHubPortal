@Html.AntiForgeryToken()
@model IEnumerable<Kursach_CorpHubPortal.Data.Entities.Position>
@{
    ViewData["Title"] = "Должности";
}

<style>
    .table td {
        vertical-align: middle;
        padding: 15px 12px;
    }

        .table td:last-child {
            white-space: nowrap;
            width: 1%;
        }

    .salary-tag {
        color: #059669;
        font-weight: 700;
        background-color: #ecfdf5;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.9rem;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-width: 120px;
        padding: 6px 12px;
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #475569;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 mb-0"><i class="bi bi-briefcase me-2"></i>Должности</h2>
        <a asp-action="CreatePosition" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Новая позиция
        </a>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-muted small text-uppercase fw-bold">Должность</th>
                        <th class="text-muted small text-uppercase fw-bold">Описание</th>
                        <th class="text-muted small text-uppercase fw-bold">Оклад</th>
                        <th class="text-center text-muted small text-uppercase fw-bold">Штат</th>
                        <th class="text-end pe-4 text-muted small text-uppercase fw-bold">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pos in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@pos.Title</div>
                            </td>
                            <td>
                                <div class="text-muted small text-truncate" style="max-width: 300px;">
                                    @(pos.Description ?? "Описание отсутствует")
                                </div>
                            </td>
                            <td>
                                @if (pos.Salary.HasValue)
                                {
                                    <span class="salary-tag">@pos.Salary.Value.ToString("C0")</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Не указан</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@pos.Employees.Count</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="dropdown">
                                    <button class="btn btn-action shadow-sm" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots"></i> Управление
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item" asp-action="EditPosition" asp-route-id="@pos.Id"><i class="bi bi-pencil me-2"></i> Редактировать</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger" href="javascript:void(0)"
                                               onclick="confirmDeletePos(@pos.Id, '@pos.Title')">
                                                <i class="bi bi-trash3 me-2"></i> Удалить
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
    function confirmDeletePos(id, name) {
        executeDelete(id, name, 'DeletePosition');
    }

    function executeDelete(id, name, action) {
        if (confirm(`Вы действительно хотите удалить "${name}"?`)) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/Admin/${action}/${id}`;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;

            form.appendChild(tokenInput);
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>