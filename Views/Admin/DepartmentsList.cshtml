@Html.AntiForgeryToken()
@model IEnumerable<Kursach_CorpHubPortal.Data.Entities.Department>
@{
    ViewData["Title"] = "Департаменты";
}

<style>
    .table td {
        vertical-align: middle;
        padding: 15px 12px;
    }

        .table td:last-child {
            white-space: nowrap;
            width: 1%;
        }

    .count-badge {
        background-color: #eef2ff;
        color: #4f46e5;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.85rem;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-width: 120px;
        padding: 6px 12px;
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #475569;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-action:hover {
            background-color: #f1f5f9;
            border-color: #cbd5e1;
            color: #1e293b;
        }
</style>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 mb-0"><i class="bi bi-building me-2"></i>Департаменты</h2>
        <a asp-action="CreateDepartment" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Новый отдел
        </a>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 text-muted small text-uppercase fw-bold">Название</th>
                        <th class="text-muted small text-uppercase fw-bold">Руководитель</th>
                        <th class="text-center text-muted small text-uppercase fw-bold">Сотрудники</th>
                        <th class="text-end pe-4 text-muted small text-uppercase fw-bold">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Name</div>
                                <div class="text-muted small">@item.Description</div>
                            </td>
                            <td>
                                @if (item.Manager != null)
                                {
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-person-badge me-2 text-primary"></i>
                                        <span>@item.Manager.LastName @item.Manager.FirstName</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Не назначен</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="count-badge">
                                    <i class="bi bi-people-fill me-1"></i> @item.Employees.Count
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="dropdown">
                                    <button class="btn btn-action shadow-sm" data-bs-toggle="dropdown">
                                        <i class="bi bi-gear"></i> Управление
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item" asp-action="EditDepartment" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i> Изменить</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item text-danger" href="javascript:void(0)"
                                               onclick="confirmDeleteDept(@item.Id, '@item.Name')">
                                                <i class="bi bi-trash3 me-2"></i> Удалить
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
    function confirmDeleteDept(id, name) {
        executeDelete(id, name, 'DeleteDepartment');
    }

    function executeDelete(id, name, action) {
        if (confirm(`Вы действительно хотите удалить "${name}"?`)) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/Admin/${action}/${id}`;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;

            form.appendChild(tokenInput);
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>