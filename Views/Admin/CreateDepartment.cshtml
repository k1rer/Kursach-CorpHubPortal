@model DepartmentDTO

@{
    ViewData["Title"] = "Управление отделом";
}

<link href="~/lib/select2/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="~/lib/select2-bootstrap-5-theme/dist/select2-bootstrap-5-theme.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Параметры отдела</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CreateDepartment" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="Введите название отдела..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ManagerId" class="form-label fw-bold"></label>
                            <select asp-for="ManagerId" class="form-select select2-manager" asp-items="ViewBag.ManagersList">
                                <option value="">-- Найти и выбрать руководителя --</option>
                            </select>
                            <div class="form-text">Начните вводить фамилию менеджера для быстрого поиска.</div>
                            <span asp-validation-for="ManagerId" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Опишите задачи отдела..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary me-md-2">Отмена</a>
                            <button type="submit" class="btn btn-primary px-5">
                                <i class="bi bi-check-lg me-1"></i> Сохранить
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="~/lib/select2/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
            $('.select2-manager').select2({
                theme: 'bootstrap-5',
                placeholder: "-- Начните вводить фамилию --",
                allowClear: true,
                language: {
                    noResults: function () {
                        return "Менеджеры не найдены";
                    }
                }
            });
        });
    </script>
}