{
  "version": "3.0",
  "defaultProvider": "unpkg",
  "libraries": [
    {
      "library": "imask@7.6.1",
      "destination": "wwwroot/lib/imask/",
      "files": [
        "dist/imask.min.js"
      ]
    },
    {
      "provider": "jsdelivr",
      "library": "select2@4.1.0-rc.0",
      "destination": "wwwroot/lib/select2/",
      "files": [
        "dist/css/select2.min.css",
        "dist/js/select2.min.js"
      ]
    },
    {
      "library": "select2-bootstrap-5-theme@1.3.0",
      "destination": "wwwroot/lib/select2-bootstrap-5-theme/"
    },
    {
      "provider": "jsdelivr",
      "library": "bootstrap-icons@1.13.1",
      "destination": "wwwroot/lib/bootstrap-icons/",
      "files": [
        "font/bootstrap-icons.min.css"
      ]
    }
  ]
}